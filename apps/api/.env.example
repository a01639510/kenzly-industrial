# Supabase → Project Settings → Database → Connection String (Transaction mode)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Orígenes permitidos (URL de Vercel)
ALLOWED_ORIGINS=https://tu-app.vercel.app

# Seguridad
JWT_SECRET=genera-uno-con-openssl-rand-hex-32
ADMIN_PASSWORD=contraseña-segura-admin

# Email alertas (opcional)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=contacto@kenzly.com.mx
SMTP_PASS=tu-password
SMTP_FROM=Kenzly Alertas <contacto@kenzly.com.mx>
